#!/bin/bash
# Jart-OS de secrets — Sync encrypted vault with ~/.env
#
# Reads ~/.env (if exists) and re-encrypts .env.enc
# Useful when keys were added outside the official editor

set -e

VAULT_DIR="${HOME}/.hermes"

if [ ! -f "${HOME}/.env" ]; then
    echo "ℹ️  No ~/.env to sync"
    exit 0
fi

if ! command -v ykchalresp >/dev/null 2>&1 || ! ykchalresp -2 "ping" >/dev/null 2>&1; then
    echo "❌ YubiKey not detected"
    exit 1
fi

# Get MASTER_KEY
YUBI_KEY=$(ykchalresp -2 "jart-os-master-2026" 2>&1)
MASTER_KEY=$(openssl enc -aes-256-cbc -d -in "${VAULT_DIR}/.master-key.yubi" -pbkdf2 -pass pass:"${YUBI_KEY}" 2>/dev/null)

# Encrypt
openssl enc -aes-256-cbc -salt -in "${HOME}/.env" -out "${VAULT_DIR}/.env.enc" -pbkdf2 -pass pass:"$MASTER_KEY"
chmod 600 "${VAULT_DIR}/.env.enc"

echo "✅ Vault synced"
