#!/bin/bash
# Jart-OS de secrets - Edit the encrypted vault
#
# Decrypts .env.enc, opens editor, re-encrypts on save.
#
# Usage:  jart-os-edit-secrets [editor]
#         (default: nano)

set -e

VAULT_DIR="${HOME}/.hermes"
EDITOR="${1:-nano}"
TMP_FILE="/tmp/.jart-os-env-$$"

cleanup() { rm -f "$TMP_FILE"; }
trap cleanup EXIT

# Verify YubiKey
if ! command -v ykchalresp >/dev/null 2>&1 || ! ykchalresp -2 "ping" >/dev/null 2>&1; then
    echo "❌ YubiKey not detected. Plug it in and try again."
    exit 1
fi

# Get MASTER_KEY
YUBI_KEY=$(ykchalresp -2 "jart-os-master-2026" 2>&1)
MASTER_KEY=$(openssl enc -aes-256-cbc -d -in "${VAULT_DIR}/.master-key.yubi" -pbkdf2 -pass pass:"${YUBI_KEY}" 2>/dev/null)
if [ -z "$MASTER_KEY" ]; then
    echo "❌ Could not decrypt MASTER_KEY"
    exit 1
fi

# Decrypt to temp file (or create empty)
if [ -f "${VAULT_DIR}/.env.enc" ]; then
    openssl enc -aes-256-cbc -d -in "${VAULT_DIR}/.env.enc" -out "$TMP_FILE" -pbkdf2 -pass pass:"$MASTER_KEY" 2>/dev/null || touch "$TMP_FILE"
else
    touch "$TMP_FILE"
fi

# Hash to detect changes
ORIGINAL_HASH=$(md5 -q "$TMP_FILE" 2>/dev/null)

"$EDITOR" "$TMP_FILE"

NEW_HASH=$(md5 -q "$TMP_FILE" 2>/dev/null)
if [ "$ORIGINAL_HASH" = "$NEW_HASH" ]; then
    echo "ℹ️  No changes"
    exit 0
fi

# Re-encrypt
openssl enc -aes-256-cbc -salt -in "$TMP_FILE" -out "${VAULT_DIR}/.env.enc" -pbkdf2 -pass pass:"$MASTER_KEY"
chmod 600 "${VAULT_DIR}/.env.enc"

echo "✅ Vault updated"
